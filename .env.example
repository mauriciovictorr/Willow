# Willow — Variáveis de Ambiente
# Copie este arquivo para .env e preencha com as suas chaves de API reais.
# NUNCA compartilhe o arquivo .env com ninguém!

# --- API Keys para LLMs (Cérebro da Willow) ---
GOOGLE_GEMINI_API_KEY=sua_chave_aqui
OPENAI_API_KEY=sua_chave_aqui

# --- Configurações de Áudio ---
# Índice do microfone padrão (use -1 para autodetectar)
MICROPHONE_INDEX=-1

# --- Configurações Gerais ---
# Idioma principal para reconhecimento de voz
WILLOW_LANGUAGE=pt-BR

# Nome da assistente (usado no Text-to-Speech)
WILLOW_NAME=Willow

# Nível de log (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
